# Database Settings
DATABASE_PATH=sqlite:///gym_management.db

# Backend Configuration
BACKEND_PORT=8000
SECRET_KEY=your-secret-key-for-password-hashing-sessions

# Hardware Configuration
# Set to 'true' to use the simulator; 'false' to connect to physical reader SDK
MOCK_HARDWARE=true
HARDWARE_READER_IP=192.168.1.201
HARDWARE_READER_PORT=4370

# AI Assistant Configuration (BYO Keys)
# Stored encrypted locally in real application, but environment overrides can be put here
GROQ_API_KEY=your_groq_api_key_here
OPENAI_API_KEY=your_openai_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here
OLLAMA_BASE_URL=http://localhost:11434
