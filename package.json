{
  "name": "gym-management-system",
  "version": "1.0.0",
  "description": "Offline-first Standalone Gym Management System",
  "main": "electron/main.js",
  "scripts": {
    "dev:frontend": "npm run dev --prefix frontend",
    "dev:backend": "python -m uvicorn app.main:app --reload --app-dir backend",
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\" \"cross-env NODE_ENV=development electron .\"",
    "install:all": "npm install && npm install --prefix frontend",
    "electron:start": "electron ."
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3",
    "electron": "^31.0.0"
  }
}
